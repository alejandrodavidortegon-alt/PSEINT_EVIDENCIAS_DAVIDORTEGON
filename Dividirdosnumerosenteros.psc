Proceso Dividirdosnumerosenteros
	Definir num1,num2,division Como Real;
	// Entrada 
	Escribir "Este es un programa para dividir";
	Escribir Sin Saltar"Digite el primer número:";
	Leer num1;
	
	Escribir Sin Saltar"Digite el segundo:";
	Leer num2;
	// Proceso 
	division <- num1 / num2;
	Escribir "La division de los dos números es:",division;
	
	
FinProceso
