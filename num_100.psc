Algoritmo num_100
	Escribir sin saltar " Diseńe un algoritmo que repita una secuencia hasta que el usuario se mayor de edad ";

	// Declarar
	Definir edad, p Como entero;
	
	Escribir "ingrese su edad";
	Leer edad;
	
	//Proceso 1
	 Mientras (Edad < 18) Hacer
		 Escribir "Eres menor de edad: ", Edad;
		 Edad <- Edad +1;
		 p <- 1;
	 FinMientras
	 Escribir "Eres mayor de edad";
FinAlgoritmo
	
